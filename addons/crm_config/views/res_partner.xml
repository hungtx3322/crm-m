        <record id="view_partner_summary_tree" model="ir.ui.view">
            <field name="name">partner.summary.list</field>
            <field name="model">partner.summary</field>
            <field name="arch" type="xml">
                <list string="Liên hệ rút gọn" create="false" edit="false" delete="false">
                    <field name="display_name"/>
                    <field name="user_id"/>
                    <field name="country_id" options="{'no_open': True, 'no_create': True}"/>
                </list>
            </field>
        </record>

        <record id="action_partner_summary" model="ir.actions.act_window">
            <field name="name">Liên hệ (readonly)</field>
            <field name="res_model">partner.summary</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem id="menu_partner_summary"
                  name="Liên hệ (readonly)"
                  action="action_partner_summary"
                  parent="contacts.menu_contacts"
                  sequence="100"/>

